# ═══════════════════════════════════════════════════════════════════════════════
# Qoder Autopilot — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control!
#
# All variables support the QODER_ prefix for pydantic-settings.
# Legacy names (SUMOPOD_*, WORKER_URL) are also supported as fallbacks.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Temp Mail (Cloudflare Worker) ──────────────────
# Your Cloudflare Worker URL for temporary email generation.
# This is required — without it, the tool cannot generate emails.
QODER_WORKER_URL=https://your-worker.workers.dev

# ── AI Captcha Solver (Optional) ───────────────────
# If not set, captcha will require manual solving (--manual-captcha).
# Supports any OpenAI-compatible API (SumoPod, OpenAI, Groq, etc.)
#
# Legacy aliases also work: SUMOPOD_API_KEY, SUMOPOD_BASE_URL, SUMOPOD_MODEL
QODER_AI_API_KEY=
QODE...n
# ── 9Router Integration (Optional) ─────────────────
# Qoder Autopilot inserts tokens directly into 9Router's SQLite DB.
# No password needed — just make sure the DB file is accessible.
QODER_NINEROUTER_DB=~/.9router/db/data.sqlite
QODER_NINEROUTER_URL=http://localhost:20128
# QODER_NINEROUTER_PASSWORD=  # Optional, rarely needed

# ── Behavior (Optional) ────────────────────────────
# Uncomment and adjust if you want to change defaults.
#
# QODER_CAPTCHA_TIMEOUT=120       # Max seconds for manual captcha solve
# QODER_OTP_TIMEOUT=120           # Max seconds to wait for OTP email
# QODER_MAX_CAPTCHA_ATTEMPTS=8    # Max automatic captcha attempts
# QODER_PARALLEL_DELAY=30         # Delay between sequential accounts (seconds)

# ── File Paths (Optional) ──────────────────────────
# QODER_SCREENSHOTS_DIR=screenshots
# QODER_CREDENTIALS_FILE=qoder_accounts.json
